# claw 环境变量示例
#
# 复制后按你的部署方式填写：
# - 本地开发可放进 .dev.vars 或用 wrangler secret put
# - Cloudflare 线上推荐用 wrangler secret put 管理敏感值

# Telegram Bot API token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram webhook 校验 secret
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# OpenAI-compatible /v1 接口的客户端访问密钥
CLAW_API_KEY=your-client-api-key

# 上游 OpenAI-compatible 服务地址；不填时走本地兜底回复
OPENAI_BASE_URL=https://api.openai.com/v1

# 上游接口鉴权 token；只在配置了 OPENAI_BASE_URL 时有用
OPENAI_API_KEY=your-openai-api-key

# 项目优先使用的模型名；可选
CLAW_MODEL=claw-mini

# 备用模型名；可选，CLAW_MODEL 未设置时才会参考
OPENAI_MODEL=gpt-4.1-mini
